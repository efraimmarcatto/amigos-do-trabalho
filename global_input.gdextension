[configuration]
entry_symbol = "global_input_library_init"
compatibility_minimum = "4.2"

[libraries]
linux.debug.x86_64 = "res://gdextension/bin/libglobal_input.linux.template_debug.x86_64.so"
linux.release.x86_64 = "res://gdextension/bin/libglobal_input.linux.template_release.x86_64.so"
windows.debug.x86_64 = "res://gdextension/bin/libglobal_input.windows.template_debug.x86_64.dll"
windows.release.x86_64 = "res://gdextension/bin/libglobal_input.windows.template_release.x86_64.dll"
